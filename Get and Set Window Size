from selenium import webdriver
from selenium.webdriver.chrome.service import Service
from webdriver_manager.chrome import ChromeDriverManager

driver = webdriver.Chrome(service=Service(ChromeDriverManager().install()))

driver.get("https://www.lambdatest.com/selenium-playground/")

# Consistent window size ensures the UI layout remains the same during
# automation. Responsive websites may display different layouts depending
# on the browser window size, so setting a fixed size improves test consistency.

print("Current Window Size:", driver.get_window_size())

driver.set_window_size(1280, 800)

print("Updated Window Size:", driver.get_window_size())

driver.quit()
